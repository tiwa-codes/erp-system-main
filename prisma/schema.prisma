enum SalesReportStatus {
  DRAFT
  SUBMITTED
  VETTED
  APPROVED
  FINAL_COPY_UPLOADED
}

model SalesReport {
  id                   String            @id @default(cuid())
  report_id            String            @unique
  submodule            SalesSubmodule
  region_id            String?
  branch_id            String?
  report_type          ReportType
  report_period        DateTime
  report_period_end    DateTime?
  title                String
  sales_amount         Decimal
  target_amount        Decimal
  state                String?
  achievement          Decimal // Calculated percentage
  notes                String?           @db.Text
  status               SalesReportStatus @default(DRAFT)
  submitted_by_id      String?
  vetted_by_id         String?
  approved_by_id       String?
  submitted_at         DateTime?
  vetted_at            DateTime?
  approved_at          DateTime?
  final_copy_url       String?
  supporting_documents Json? // Array of file URLs
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt
  region               SalesRegion?      @relation(fields: [region_id], references: [id])
  branch               SalesBranch?      @relation(fields: [branch_id], references: [id])
  submitted_by         User?             @relation("SubmittedSalesReports", fields: [submitted_by_id], references: [id])
  vetted_by            User?             @relation("VettedSalesReports", fields: [vetted_by_id], references: [id])
  approved_by          User?             @relation("ApprovedSalesReports", fields: [approved_by_id], references: [id])

  @@index([submodule])
  @@index([region_id])
  @@index([branch_id])
  @@index([report_type])
  @@index([status])
  @@index([report_period])
  @@index([submitted_by_id])
  @@index([report_id])
  @@map("sales_reports")
}

model SalesRegion {
  id         String              @id @default(cuid())
  name       String              @unique
  is_active  Boolean             @default(true)
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt
  branches   SalesBranch[]
  targets    SalesBranchTarget[]
  reports    SalesReport[]

  @@index([is_active])
  @@map("sales_regions")
}

model SalesBranch {
  id         String              @id @default(cuid())
  region_id  String
  name       String
  state      String
  is_active  Boolean             @default(true)
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt
  region     SalesRegion         @relation(fields: [region_id], references: [id])
  targets    SalesBranchTarget[]
  reports    SalesReport[]

  @@unique([region_id, name])
  @@index([region_id])
  @@index([state])
  @@index([is_active])
  @@map("sales_branches")
}

model SalesBranchTarget {
  id            String        @id @default(cuid())
  region_id     String
  branch_id     String
  submodule     SalesSubmodule
  annual_target Decimal       @default(0)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  region        SalesRegion   @relation(fields: [region_id], references: [id])
  branch        SalesBranch   @relation(fields: [branch_id], references: [id])

  @@unique([region_id, branch_id, submodule])
  @@index([region_id])
  @@index([branch_id])
  @@index([submodule])
  @@map("sales_branch_targets")
}

model TelemedicineRequest {
  id             String                @id @default(cuid())
  appointment_id String
  enrollee_id    String
  request_type   String // "LAB", "RADIOLOGY", "PHARMACY", "REFERRAL"
  facility_id    String?
  test_name      String?
