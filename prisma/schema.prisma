model TelemedicineAppointment {
  id               String            @id @default(cuid())
  enrollee_id      String
  dependent_id     String?           // If null, appointment is for principal; if set, appointment is for this dependent
  provider_id      String?
  appointment_type AppointmentType   @default(WALK_IN)
  reason           String?
  scheduled_date   DateTime
  status           AppointmentStatus @default(SCHEDULED)
  clinic           String?
  specialization   String? // Specialization selected during booking
  state            String? // State selected during booking
  lga              String? // Local Government Area (optional)
  notes            String?
  created_by_id    String?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  // Relations
  enrollee              PrincipalAccount      @relation(fields: [enrollee_id], references: [id])
  dependent             Dependent?            @relation(fields: [dependent_id], references: [id])
  provider              Provider?             @relation(fields: [provider_id], references: [id])
  created_by            User?                 @relation(fields: [created_by_id], references: [id])
  clinical_encounters   ClinicalEncounter[]
  lab_orders            LabOrder[]
  radiology_orders      RadiologyOrder[]
  pharmacy_orders       PharmacyOrder[]
  referrals             Referral[]
  telemedicine_requests TelemedicineRequest[]

  @@index([enrollee_id])
  @@index([dependent_id])
  @@index([provider_id])
  @@index([scheduled_date])
  @@index([status])
  @@map("telemedicine_appointments")
}

model ClinicalEncounter {
  id                    String          @id @default(cuid())
  appointment_id        String
  presenting_complaints String?
  clinical_notes        String?
  assessment            String?
  diagnosis             String?
  plan_notes            String?
  status                EncounterStatus @default(IN_PROGRESS)
  created_by_id         String
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  // Relations
  appointment TelemedicineAppointment @relation(fields: [appointment_id], references: [id])
  created_by  User                    @relation(fields: [created_by_id], references: [id])

  @@index([appointment_id])
  @@index([status])
  @@map("clinical_encounters")
}

model TelemedicineFacility {
  id             String         @id @default(cuid())
  facility_name  String
  phone_number   String
  email          String
  facility_type  FacilityType
  selected_bands String[] // Array of band labels for this facility
  status         FacilityStatus @default(ACTIVE)
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  // Relations
  lab_orders            LabOrder[]
  radiology_orders      RadiologyOrder[]
  pharmacy_orders       PharmacyOrder[]
  telemedicine_requests TelemedicineRequest[]
  tariffs               FacilityTariff[]

  @@index([facility_type])
  @@index([status])
  @@map("telemedicine_facilities")
}

model FacilityTariff {
  id          String   @id @default(cuid())
  facility_id String
  service_id  String
  price       Float
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  facility TelemedicineFacility @relation(fields: [facility_id], references: [id], onDelete: Cascade)
  service  ServiceType          @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@unique([facility_id, service_id])
  @@index([facility_id])
  @@index([service_id])
  @@map("facility_tariffs")
}

model LabOrder {
  id              String      @id @default(cuid())
  appointment_id  String
  facility_id     String
  test_name       String
  status          OrderStatus @default(PENDING)
  requested_by    String
  amount          Float?
  results         String?
  findings        String?
  recommendations String?
  notes           String?
  pdf_report      String?
  submitted_at    DateTime?
  completed_at    DateTime?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  // Relations
  appointment TelemedicineAppointment @relation(fields: [appointment_id], references: [id])
  facility    TelemedicineFacility    @relation(fields: [facility_id], references: [id])

  @@index([appointment_id])
  @@index([facility_id])
  @@index([status])
  @@map("lab_orders")
}

model RadiologyOrder {
  id              String      @id @default(cuid())
  appointment_id  String
  facility_id     String
  test_name       String
  status          OrderStatus @default(PENDING)
  requested_by    String
  amount          Float?
  results         String?
  findings        String?
  recommendations String?
  notes           String?
  pdf_report      String?
  submitted_at    DateTime?
  completed_at    DateTime?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  // Relations
  appointment TelemedicineAppointment @relation(fields: [appointment_id], references: [id])
  facility    TelemedicineFacility    @relation(fields: [facility_id], references: [id])

  @@index([appointment_id])
  @@index([facility_id])
  @@index([status])
  @@map("radiology_orders")
}

model PharmacyOrder {
