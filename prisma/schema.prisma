enum JournalEntryType {
  MANUAL
  SYSTEM_GENERATED
}

enum JournalEntryStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED
  REJECTED
}

enum PostingType {
  DEBIT
  CREDIT
}

model ChartOfAccount {
  id                String          @id @default(cuid())
  account_code      Int             @unique
  account_name      String
  account_category  AccountCategory
  sub_category      String?
  parent_account_id String?
  is_active         Boolean         @default(true)
  description       String?
  opening_balance   Decimal         @default(0) @db.Decimal(15, 2)
  balance_type      PostingType?
  created_by_id     String?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  parent_account         ChartOfAccount?    @relation("ChartOfAccountHierarchy", fields: [parent_account_id], references: [id])
  child_accounts         ChartOfAccount[]   @relation("ChartOfAccountHierarchy")
  created_by             User?              @relation("CreatedChartOfAccounts", fields: [created_by_id], references: [id])
  general_ledger_entries GeneralLedger[]
  journal_entry_lines    JournalEntryLine[]

  @@index([account_code])
  @@index([account_category])
  @@index([is_active])
  @@index([parent_account_id])
  @@map("chart_of_accounts")
}

model GeneralLedger {
  id               String      @id @default(cuid())
  entry_number     String      @unique
  transaction_date DateTime
  reference_number String?
  reference_type   String? // CLAIM, PREMIUM, PROCUREMENT, PAYROLL, JOURNAL_ENTRY, etc.
  reference_id     String?
  account_id       String
  posting_type     PostingType
  amount           Decimal     @db.Decimal(15, 2)
  description      String?
  module           String? // claims, underwriting, procurement, hr, etc.
  journal_entry_id String?
  created_by_id    String?
  created_at       DateTime    @default(now())

  account                ChartOfAccount         @relation(fields: [account_id], references: [id])
  journal_entry          JournalEntry?          @relation(fields: [journal_entry_id], references: [id])
  created_by             User?                  @relation("CreatedGLEntries", fields: [created_by_id], references: [id])
  financial_transactions FinancialTransaction[]
  payouts                Payout[]

  @@index([account_id])
  @@index([transaction_date])
  @@index([reference_type])
  @@index([reference_id])
  @@index([journal_entry_id])
  @@index([module])
  @@map("general_ledger")
}

model JournalEntry {
  id                      String             @id @default(cuid())
  entry_number            String             @unique
  entry_date              DateTime
  entry_type              JournalEntryType
  status                  JournalEntryStatus @default(DRAFT)
  description             String?
  total_debit             Decimal            @db.Decimal(15, 2)
  total_credit            Decimal            @db.Decimal(15, 2)
  supporting_document_url String?
  created_by_id           String?
  approved_by_id          String?
  approved_at             DateTime?
  rejection_reason        String?
  posted_at               DateTime?
  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt

  created_by             User?              @relation("CreatedJournalEntries", fields: [created_by_id], references: [id])
  approved_by            User?              @relation("ApprovedJournalEntries", fields: [approved_by_id], references: [id])
  journal_entry_lines    JournalEntryLine[]
  general_ledger_entries GeneralLedger[]

  @@index([entry_number])
  @@index([entry_date])
  @@index([entry_type])
  @@index([status])
  @@index([created_by_id])
  @@map("journal_entries")
}

model JournalEntryLine {
  id               String      @id @default(cuid())
  journal_entry_id String
  account_id       String
  posting_type     PostingType
  amount           Decimal     @db.Decimal(15, 2)
  description      String?
  created_at       DateTime    @default(now())

  journal_entry JournalEntry   @relation(fields: [journal_entry_id], references: [id], onDelete: Cascade)
  account       ChartOfAccount @relation(fields: [account_id], references: [id])

  @@index([journal_entry_id])
  @@index([account_id])
  @@map("journal_entry_lines")
}

model DatabaseBackup {
  id            String       @id @default(cuid())
  backup_name   String // User-friendly name
  backup_type   BackupType   @default(FULL)
  file_path     String // Local file path
  cloud_url     String? // Cloudinary URL (if uploaded)
  file_size     Int? // Size in bytes (optional until backup completes)
  status        BackupStatus @default(IN_PROGRESS)
  error_message String?
  created_by_id String
  created_by    User         @relation("CreatedBackups", fields: [created_by_id], references: [id])
  created_at    DateTime     @default(now())
  completed_at  DateTime?
  expires_at    DateTime? // Auto-delete after this date
  metadata      Json? // Additional metadata (tables count, etc.)

  @@index([created_by_id])
  @@index([status])
  @@index([created_at])
  @@map("database_backups")
}

model BackupSchedule {
  id             String            @id @default(cuid())
  frequency      ScheduleFrequency
  time           String // Time in HH:MM format
  backup_type    BackupType        @default(FULL)
  retention_days Int               @default(30)
  is_active      Boolean           @default(true)
  last_run_at    DateTime?
  next_run_at    DateTime?
  created_by_id  String
  created_by     User              @relation("CreatedBackupSchedules", fields: [created_by_id], references: [id])
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  @@index([is_active])
  @@index([next_run_at])
  @@map("backup_schedules")
}

enum BackupType {
  FULL // Complete database backup
  SCHEMA_ONLY // Schema only (no data)
  DATA_ONLY // Data only (no schema)
}

enum BackupStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  DELETED
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// Global service pool for Plan Management Customize
// Services from all providers sync here to avoid duplicates
model GlobalService {
  id            String   @id @default(cuid())
  service_name  String
  category_id   String
  category_name String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@unique([service_name, category_id])
  @@index([category_id])
  @@index([is_active])
  @@map("global_services")
}

// Global drug list for approval code requests
// Drugs sync here when added in approval requests
model GlobalDrug {
  id         String   @id @default(cuid())
  drug_name  String   @unique
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([is_active])
  @@map("global_drugs")
}

// Provider tariff file storage
// Stores original Excel files uploaded by providers
model ProviderTariffFile {
  id          String   @id @default(cuid())
  provider_id String   @unique
  file_name   String
  file_path   String
  file_size   Int
  mime_type   String   @default("application/vnd.openxmlformats-officedocument.spreadsheetml.sheet")
  uploaded_at DateTime @default(now())
  uploaded_by String

  provider Provider @relation(fields: [provider_id], references: [id])
  uploader User     @relation("UploadedTariffFiles", fields: [uploaded_by], references: [id])

  @@index([provider_id])
  @@map("provider_tariff_files")
}

// Stores ICD-10 diagnosis codes for encounter code requests
model Diagnosis {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([code])
  @@index([description])
  @@map("diagnoses")
}

// Clients Plans Module
// Stores custom plan submissions from clients via mobile app
model ClientPlan {
  id                    String                 @id @default(cuid())
  client_plan_id        String                 @unique @default(uuid()) // Unique reference ID
  organization_id       String
  principal_account_id  String?
  client_account_id     String?
  plan_name             String
  plan_description      String?
  requested_premium     Decimal?               // Client-preferred premium amount
  requested_annual_limit Decimal?              // Client-preferred annual limit
  status                ClientPlanStatus       @default(DRAFT)
  total_price           Decimal?               // Admin-set total price for the custom plan
  invoice_id            String?                // Reference to generated invoice
  notification_read     Boolean                @default(false)
  submitted_at          DateTime?              // When client submitted the draft
  reviewed_at           DateTime?              // When admin reviewed it
  reviewed_by_id        String?                // Admin who reviewed
  approved_at           DateTime?              // When approved
  approved_by_id        String?                // Admin who approved
  rejected_at           DateTime?              // When rejected
  rejected_by_id        String?                // Admin who rejected
  rejection_reason      String?                // Why it was rejected
  invoice_sent_at       DateTime?              // When invoice was sent
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  
  organization          Organization           @relation(fields: [organization_id], references: [id])
  principal_account     PrincipalAccount?      @relation(fields: [principal_account_id], references: [id])
  client_account        ClientAccount?         @relation(fields: [client_account_id], references: [id])
  reviewed_by           User?                  @relation("ClientPlanReviewedBy", fields: [reviewed_by_id], references: [id])
  approved_by           User?                  @relation("ClientPlanApprovedBy", fields: [approved_by_id], references: [id])
  rejected_by           User?                  @relation("ClientPlanRejectedBy", fields: [rejected_by_id], references: [id])
  services              ClientPlanService[]
  invoice               ClientPlanInvoice?

  @@index([organization_id])
  @@index([principal_account_id])
  @@index([client_account_id])
  @@index([status])
  @@index([submitted_at])
  @@index([created_at])
  @@map("client_plans")
}

// Individual services selected by client for their custom plan
model ClientPlanService {
  id                    String                 @id @default(cuid())
  client_plan_id        String
  service_type_id       String
  category              String                 // e.g., "General Consultation", "Lab"
  service_name          String
  quantity              Int                    @default(1)
  unit_price            Decimal
  total_amount          Decimal                // quantity * unit_price
  frequency_limit       Int?                   // How many times per year/period
  price_limit           Decimal?               // Maximum amount covered
  category_price_limit  Decimal?               // Category-level amount cap from package customization
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  
  client_plan           ClientPlan             @relation(fields: [client_plan_id], references: [id], onDelete: Cascade)
  service_type          ServiceType            @relation(fields: [service_type_id], references: [id])

  @@index([client_plan_id])
  @@index([service_type_id])
  @@map("client_plan_services")
}

// Generated invoice for approved client plans
model ClientPlanInvoice {
  id                    String                 @id @default(cuid())
  invoice_number        String                 @unique
  client_plan_id        String                 @unique
  organization_name     String
  client_name           String
  client_email          String
  total_amount          Decimal
  currency              String                 @default("NGN")
  invoice_date          DateTime               @default(now())
  due_date              DateTime?
  paid_at               DateTime?
  invoice_data          Json?                  // Stores detailed invoice JSON (services breakdown, etc.)
  pdf_path              String?                // Path to generated PDF
  status                InvoiceStatus          @default(PENDING)
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  
  client_plan           ClientPlan             @relation(fields: [client_plan_id], references: [id], onDelete: Cascade)

  @@index([client_plan_id])
  @@index([invoice_number])
  @@index([status])
  @@map("client_plan_invoices")
}

// Enum for client plan status
enum ClientPlanStatus {
  DRAFT      // Client is still building the plan on mobile
  PENDING    // Client submitted, awaiting admin review
  REVIEW     // Admin is reviewing the plan
  APPROVED   // Plan approved, invoice generated
  REJECTED   // Plan rejected by admin
  INVOICED   // Invoice has been sent to client
  PAID       // Client has paid
}
