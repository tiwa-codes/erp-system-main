generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                String                    @id @default(cuid())
  email                             String                    @unique
  password                          String?
  first_name                        String
  last_name                         String
  title                             String?
  date_of_birth                     DateTime?
  gender                            String?
  phone_number                      String?
  contact_address                   String?
  role_id                           String?
  status                            UserStatus                @default(ACTIVE)
  department_id                     String?
  last_login_at                     DateTime?
  email_verified                    DateTime?
  email_verification_token          String?
  password_reset_token              String?
  password_reset_expires            DateTime?
  created_at                        DateTime                  @default(now())
  updated_at                        DateTime                  @updatedAt
  provider_id                       String?
  first_login                       Boolean                   @default(true)
  last_login                        DateTime?
  profile_picture                   String?
  generated_approval_codes          ApprovalCode[]            @relation("GeneratedApprovalCodes")
  deleted_approval_codes            ApprovalCode[]            @relation("DeletedApprovalCodes")
  added_approval_code_services      ApprovalCodeService[]     @relation("AddedApprovalCodeServices")
  audit_logs                        AuditLog[]
  claim_audits                      ClaimAudit[]              @relation("ClaimAudits")
  created_claims                    Claim[]                   @relation("CreatedBy")
  created_dependents                Dependent[]
  created_employees                 Employee[]                @relation("CreatedBy")
  created_financial_transactions    FinancialTransaction[]    @relation("CreatedBy")
  created_fraud_rules               FraudRule[]               @relation("CreatedFraudRules")
  created_hr_rules                  HRRule[]                  @relation("CreatedHRRule")
  approved_leave_requests           LeaveRequest[]            @relation("ApprovedLeaveRequests")
  created_plans                     Plan[]
  created_principal_accounts        PrincipalAccount[]        @relation("PrincipalCreatedBy")
  created_procurement_invoices      ProcurementInvoice[]      @relation("CreatedProcurementInvoices")
  dept_oversight_procurements       ProcurementInvoice[]      @relation("ProcurementDeptOversightBy")
  operations_procurements           ProcurementInvoice[]      @relation("ProcurementOperationsBy")
  executive_procurements            ProcurementInvoice[]      @relation("ProcurementExecutiveBy")
  generated_reports                 Report[]                  @relation("GeneratedReports")
  role                              Role?                     @relation(fields: [role_id], references: [id])
  department                        Department?               @relation(fields: [department_id], references: [id])
  provider                          Provider?                 @relation(fields: [provider_id], references: [id])
  vetting_records                   VettingRecord[]           @relation("VettingRecords")
  vetting_actions                   VettingAction[]           @relation("VettingActions")
  vetting_drafts                    VettingDraft[]            @relation("VettingDrafts")
  price_edits                       PriceEdit[]               @relation("PriceEdits")
  created_telemedicine_appointments TelemedicineAppointment[]
  created_clinical_encounters       ClinicalEncounter[]
  created_telemedicine_requests     TelemedicineRequest[]
  approved_tariff_plans             TariffPlan[]              @relation("ApprovedTariffPlans")
  generated_msas                    MSA[]                     @relation("GeneratedMSAs")
  mobile_updates_created            MobileUpdate[]            @relation("MobileUpdatesCreated")
  special_risk_approved_plans       Plan[]                    @relation("SpecialRiskApprovedPlans")
  md_approved_plans                 Plan[]                    @relation("MDApprovedPlans")
  approved_special_providers        SpecialProvider[]         @relation("ApprovedSpecialProviders")
  created_exchange_rates            ExchangeRate[]            @relation("CreatedExchangeRates")
  created_legal_documents           LegalDocument[]           @relation("CreatedLegalDocuments")
  vetted_legal_documents            LegalDocument[]           @relation("VettedLegalDocuments")
  approved_legal_documents          LegalDocument[]           @relation("ApprovedLegalDocuments")
  created_meeting_minutes           MeetingMinutes[]          @relation("CreatedMeetingMinutes")
  vetted_meeting_minutes            MeetingMinutes[]          @relation("VettedMeetingMinutes")
  approved_meeting_minutes          MeetingMinutes[]          @relation("ApprovedMeetingMinutes")
  document_signatures               DocumentSignature[]
  submitted_sales_reports           SalesReport[]             @relation("SubmittedSalesReports")
  vetted_sales_reports              SalesReport[]             @relation("VettedSalesReports")
  approved_sales_reports            SalesReport[]             @relation("ApprovedSalesReports")
  created_chart_of_accounts         ChartOfAccount[]          @relation("CreatedChartOfAccounts")
  created_general_ledger_entries    GeneralLedger[]           @relation("CreatedGLEntries")
  created_journal_entries           JournalEntry[]            @relation("CreatedJournalEntries")
  approved_journal_entries          JournalEntry[]            @relation("ApprovedJournalEntries")
  created_backups                   DatabaseBackup[]          @relation("CreatedBackups")
  created_backup_schedules          BackupSchedule[]          @relation("CreatedBackupSchedules")
  memo_comments                     MemoComment[]             @relation("MemoComments")
  dept_oversight_approved_memos     Memo[]                    @relation("DeptOversightApprover")
  executive_approved_memos          Memo[]                    @relation("ExecutiveApprover")
  sent_memos                        Memo[]                    @relation("MemoSender")
  received_memos                    MemoRecipient[]           @relation("MemoRecipients")
  uploaded_tariff_files             ProviderTariffFile[]      @relation("UploadedTariffFiles")
  reviewed_principal_registrations  PrincipalRegistration[]   @relation("ReviewedPrincipalRegistrations")
  approved_principal_registrations  PrincipalRegistration[]   @relation("ApprovedPrincipalRegistrations")
  rejected_principal_registrations  PrincipalRegistration[]   @relation("RejectedPrincipalRegistrations")
  approved_dependent_registrations  DependentRegistration[]   @relation("ApprovedDependentRegistrations")
  rejected_dependent_registrations  DependentRegistration[]   @relation("RejectedDependentRegistrations")
  approval_code_timeline            ApprovalCodeTimeline[]    @relation("ApprovalCodeTimelineUser")
  principal_account                  PrincipalAccount?         @relation("PrincipalUser")
  client_account                     ClientAccount?           @relation("ClientUser")
  push_token                         String?
  utilization_imports                UtilizationImport[]      @relation("CreatedUtilizationImports")
  client_plan_reviewed               ClientPlan[]             @relation("ClientPlanReviewedBy")
  client_plan_approved               ClientPlan[]             @relation("ClientPlanApprovedBy")
  client_plan_rejected               ClientPlan[]             @relation("ClientPlanRejectedBy")

  @@index([email])
  @@index([role_id])
  @@index([department_id])
  @@index([provider_id])
  @@map("users")
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  manager_id  String?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  employees   Employee[]
  users       User[]

  @@map("departments")
}

model Employee {
  id                             String             @id @default(cuid())
  employee_id                    String             @unique
  first_name                     String
  last_name                      String
  email                          String             @unique
  phone_number                   String?
  address                        String?
  title                          String?
  emergency_contact_name         String?
  emergency_contact_phone        String?
  emergency_contact_relationship String?
  position                       String
  department_id                  String
  hire_date                      DateTime
  salary                         Decimal?
  gender                         Gender?
  employment_type                EmploymentType     @default(FULL_TIME)
  status                         EmployeeStatus     @default(ACTIVE)
  role                           String?
  uploadedFileUrls               Json?
  created_by_id                  String?
  created_at                     DateTime           @default(now())
  updated_at                     DateTime           @updatedAt
  attendance_records             AttendanceRecord[]
  created_by                     User?              @relation("CreatedBy", fields: [created_by_id], references: [id])
  department                     Department         @relation(fields: [department_id], references: [id])
  leave_requests                 LeaveRequest[]
  memos                          Memo[]
  payroll_records                Payroll[]

  @@index([employee_id])
  @@index([department_id])
  @@index([status])
  @@map("employees")
}

model AttendanceRecord {
  id           String           @id @default(cuid())
  employee_id  String
  date         DateTime
  clock_in     DateTime?
  clock_out    DateTime?
  hours_worked Decimal?
  status       AttendanceStatus @default(PRESENT)
  notes        String?
  created_at   DateTime         @default(now())
  employee     Employee         @relation(fields: [employee_id], references: [id])

  @@index([employee_id])
  @@index([date])
  @@map("attendance_records")
}

model LeaveRequest {
  id             String      @id @default(cuid())
  employee_id    String
  leave_type     LeaveType
  start_date     DateTime
  end_date       DateTime
  days_requested Int
  reason         String?
  status         LeaveStatus @default(PENDING)
  approved_at    DateTime?
  created_at     DateTime    @default(now())
  approved_by_id String?
  approved_by    User?       @relation("ApprovedLeaveRequests", fields: [approved_by_id], references: [id])
  employee       Employee    @relation(fields: [employee_id], references: [id])

  @@index([employee_id])
  @@index([status])
  @@map("leave_requests")
}

model Memo {
  id          String       @id @default(cuid())
  title       String
  content     String
  employee_id String?
  priority    MemoPriority @default(NORMAL)
  status      MemoStatus   @default(DRAFT)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  // Approval workflow fields
  memo_type        MemoType @default(STANDARD)
  rejection_reason String?

  // Department Oversight approval
  dept_oversight_status      ApprovalStatus?
  dept_oversight_approved_by String?
  dept_oversight_approved_at DateTime?
  dept_oversight_comments    String?

  // Executive Desk approval
  executive_status      ApprovalStatus?
  executive_approved_by String?
  executive_approved_at DateTime?
  executive_comments    String?

  // Sender (system user) and module context
  sender_user_id String?
  module         String?

  // Relations
  employee                Employee?       @relation(fields: [employee_id], references: [id])
  sender_user             User?           @relation("MemoSender", fields: [sender_user_id], references: [id])
  dept_oversight_approver User?           @relation("DeptOversightApprover", fields: [dept_oversight_approved_by], references: [id])
  executive_approver      User?           @relation("ExecutiveApprover", fields: [executive_approved_by], references: [id])
  comments                MemoComment[]
  recipients              MemoRecipient[]

  @@index([employee_id])
  @@index([sender_user_id])
  @@index([status])
  @@index([memo_type])
  @@index([module])
  @@map("memos")
}

model MemoComment {
  id         String   @id @default(cuid())
  memo_id    String
  user_id    String
  comment    String
  created_at DateTime @default(now())

  memo Memo @relation(fields: [memo_id], references: [id], onDelete: Cascade)
  user User @relation("MemoComments", fields: [user_id], references: [id])

  @@index([memo_id])
  @@map("memo_comments")
}

model MemoRecipient {
  id         String    @id @default(cuid())
  memo_id    String
  user_id    String
  read_at    DateTime?
  created_at DateTime  @default(now())

  memo Memo @relation(fields: [memo_id], references: [id], onDelete: Cascade)
  user User @relation("MemoRecipients", fields: [user_id], references: [id])

  @@unique([memo_id, user_id])
  @@index([memo_id])
  @@index([user_id])
  @@map("memo_recipients")
}

model HRRule {
  id            String     @id @default(cuid())
  name          String
  description   String?
  rule_type     HRRuleType
  conditions    Json
  actions       Json
  is_active     Boolean    @default(true)
  priority      Int        @default(0)
  created_by_id String?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  created_by    User?      @relation("CreatedHRRule", fields: [created_by_id], references: [id])

  @@index([rule_type])
  @@index([is_active])
  @@index([priority])
  @@map("hr_rules")
}

model Payroll {
  id               String        @id @default(cuid())
  employee_id      String
  pay_period_start DateTime
  pay_period_end   DateTime
  basic_salary     Decimal
  allowances       Decimal?      @default(0)
  deductions       Decimal?      @default(0)
  overtime_pay     Decimal?      @default(0)
  net_salary       Decimal
  status           PayrollStatus @default(PENDING)
  payment_date     DateTime?
  processed_by     String?
  processed_at     DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
  employee         Employee      @relation(fields: [employee_id], references: [id])

  @@index([employee_id])
  @@index([status])
  @@index([pay_period_start])
  @@map("payroll")
}

model Claim {
  id                      String            @id @default(cuid())
  claim_number            String            @unique
  enrollee_id             String
  principal_id            String?
  provider_id             String? // Made optional for telemedicine claims
  claim_type              ClaimType
  amount                  Decimal // Current amount (can be edited by Auditor/MD)
  original_amount         Decimal           @default(0) // Original amount from provider
  approved_amount         Decimal? // Final approved amount (after all edits)
  original_currency       String?           @default("NGN")
  original_amount_foreign Decimal? // Original amount in foreign currency
  exchange_rate_used      Decimal?
  exchange_rate_date      DateTime?
  exchange_rate_id        String?
  exchange_rate           ExchangeRate?     @relation(fields: [exchange_rate_id], references: [id])
  status                  ClaimStatus       @default(SUBMITTED)
  current_stage           String? // Current stage: 'vetter1' | 'vetter2' | 'audit' | 'approval'
  submitted_at            DateTime          @default(now())
  processed_at            DateTime?
  approved_at             DateTime?
  rejected_at             DateTime?
  rejection_reason        String?
  created_by_id           String?
  created_at              DateTime          @default(now())
  updated_at              DateTime          @updatedAt
  description             String? // Description of the claim
  // Telemedicine order links
  lab_order_id            String? // Link to lab order if from telemedicine
  radiology_order_id      String? // Link to radiology order if from telemedicine
  pharmacy_order_id       String? // Link to pharmacy order if from telemedicine
  audit_records           ClaimAudit[]
  created_by              User?             @relation("CreatedBy", fields: [created_by_id], references: [id])
  principal               PrincipalAccount? @relation(fields: [principal_id], references: [id])
  provider                Provider?         @relation(fields: [provider_id], references: [id]) // Made optional
  fraud_alerts            FraudAlert[]
  payouts                 Payout[]
  vetting_records         VettingRecord[]
  approval_codes          ApprovalCode[] // Reverse relation to approval codes
  vetting_actions         VettingAction[] // Track all vetting actions
  vetting_drafts          VettingDraft[] // Auto-save drafts
  price_edits             PriceEdit[] // Price edit history

  @@index([claim_number])
  @@index([enrollee_id])
  @@index([principal_id])
  @@index([provider_id])
  @@index([status])
  @@index([current_stage])
  @@map("claims")
}

model VettingRecord {
  id              String        @id @default(cuid())
  claim_id        String
  vetter_id       String
  vetting_type    VettingType
  status          VettingStatus @default(IN_PROGRESS)
  findings        String?
  recommendations String?
  completed_at    DateTime?
  created_at      DateTime      @default(now())
  claim           Claim         @relation(fields: [claim_id], references: [id])
  vetter          User          @relation("VettingRecords", fields: [vetter_id], references: [id])

  @@index([claim_id])
  @@index([vetter_id])
  @@map("vetting_records")
}

model VettingAction {
  id               String   @id @default(cuid())
  claim_id         String
  stage            String // 'vetter1' | 'vetter2' | 'audit' | 'approval'
  action           String // 'APPROVED' | 'REJECTED' | 'REJECTED_BACK'
  action_by_id     String
  comments         String?
  service_verdicts Json? // Store service-level verdicts
  attachments      Json? // Array of {name, url, size} uploaded by this stage
  created_at       DateTime @default(now())
  claim            Claim    @relation(fields: [claim_id], references: [id])
  action_by        User     @relation("VettingActions", fields: [action_by_id], references: [id])

  @@index([claim_id])
  @@index([stage])
  @@index([action_by_id])
  @@map("vetting_actions")
}

model VettingDraft {
  id          String   @id @default(cuid())
  claim_id    String
  stage       String // 'vetter1' | 'vetter2' | 'audit' | 'approval'
  draft_data  Json // All vetting data (comments, service verdicts, etc.)
  saved_by_id String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  claim       Claim    @relation(fields: [claim_id], references: [id])
  saved_by    User     @relation("VettingDrafts", fields: [saved_by_id], references: [id])

  @@unique([claim_id, stage, saved_by_id])
  @@index([claim_id])
  @@index([saved_by_id])
  @@map("vetting_drafts")
}

model PriceEdit {
  id           String   @id @default(cuid())
  claim_id     String
  old_amount   Decimal
  new_amount   Decimal
  edited_by_id String
  stage        String // Which stage the edit was made
  reason       String?
  created_at   DateTime @default(now())
  claim        Claim    @relation(fields: [claim_id], references: [id])
  edited_by    User     @relation("PriceEdits", fields: [edited_by_id], references: [id])

  @@index([claim_id])
  @@index([edited_by_id])
  @@map("price_edits")
}

model ClaimAudit {
  id           String      @id @default(cuid())
  claim_id     String
  auditor_id   String
  audit_type   AuditType
  findings     String?
  status       AuditStatus @default(IN_PROGRESS)
  completed_at DateTime?
  created_at   DateTime    @default(now())
  auditor      User        @relation("ClaimAudits", fields: [auditor_id], references: [id])
  claim        Claim       @relation(fields: [claim_id], references: [id])

  @@index([claim_id])
  @@index([auditor_id])
  @@map("claim_audits")
}

model FraudAlert {
  id          String         @id @default(cuid())
  claim_id    String
  alert_type  FraudAlertType
  severity    AlertSeverity  @default(MEDIUM)
  description String
  status      FraudStatus    @default(OPEN)
  assigned_to String?
  resolved_at DateTime?
  created_at  DateTime       @default(now())
  is_read     Boolean        @default(false)
  claim       Claim          @relation(fields: [claim_id], references: [id])

  @@index([claim_id])
  @@index([status])
  @@map("fraud_alerts")
}

model FinancialTransaction {
  id                      String            @id @default(cuid())
  transaction_type        TransactionType
  amount                  Decimal
  currency                String            @default("NGN")
  original_currency       String?           @default("NGN")
  original_amount         Decimal?
  exchange_rate_used      Decimal?
  reference_id            String?
  reference_type          String?
  description             String?
  status                  TransactionStatus @default(PENDING)
  processed_at            DateTime?
  created_by_id           String?
  general_ledger_entry_id String?
  chart_of_account_id     String?
  created_at              DateTime          @default(now())
  created_by              User?             @relation("CreatedBy", fields: [created_by_id], references: [id])
  general_ledger_entry    GeneralLedger?    @relation(fields: [general_ledger_entry_id], references: [id])

  @@index([transaction_type])
  @@index([status])
  @@index([general_ledger_entry_id])
  @@map("financial_transactions")
}

model PrincipalAccount {
  id                        String                    @id @default(cuid())
  enrollee_id               String                    @unique @default("TEMP")
  first_name                String
  last_name                 String
  middle_name               String?
  gender                    Gender?
  date_of_birth             DateTime?
  age                       Int?
  profile_picture           String?
  marital_status            MaritalStatus?
  region                    String?
  state                     String?
  lga                       String?
  phone_number              String?
  email                     String?
  residential_address       String?
  business_type             String?
  organization_id           String
  plan_id                   String?
  account_type              AccountType
  balance                   Decimal                   @default(0)
  old_utilization           Decimal                   @default(0)
  auto_renewal              Boolean                   @default(false)
  primary_hospital          String?
  hospital_address          String?
  start_date                DateTime?
  end_date                  DateTime?
  status                    AccountStatus             @default(ACTIVE)
  created_at                DateTime                  @default(now())
  updated_at                DateTime                  @updatedAt
  created_by_id             String
  user_id                   String?                   @unique
  approval_codes            ApprovalCode[]
  claims                    Claim[]
  dependents                Dependent[]
  medical_history           MedicalHistory?
  created_by                User                      @relation("PrincipalCreatedBy", fields: [created_by_id], references: [id])
  user                      User?                     @relation("PrincipalUser", fields: [user_id], references: [id])
  organization              Organization              @relation(fields: [organization_id], references: [id])
  plan                      Plan?                     @relation(fields: [plan_id], references: [id])
  provider_requests         ProviderRequest[]
  telemedicine_appointments TelemedicineAppointment[]
  telemedicine_requests     TelemedicineRequest[]
  utilization_imports       UtilizationImport[]
  client_plans              ClientPlan[]
  dependent_registrations   DependentRegistration[] @relation("PrincipalDependentRegistrations")

  @@index([organization_id])
  @@index([plan_id])
  @@index([created_by_id])
  @@index([enrollee_id])
  @@index([user_id])
  @@map("principal_accounts")
}

model MedicalHistory {
  id                       String           @id @default(cuid())
  principal_account_id     String           @unique
  sickle_cell_disease      Boolean          @default(false)
  kidney_disease           Boolean          @default(false)
  epilepsy                 Boolean          @default(false)
  cancer_prostate_cervical Boolean          @default(false)
  asthma                   Boolean          @default(false)
  hiv_aids                 Boolean          @default(false)
  surgeries                Boolean          @default(false)
  diabetes_mellitus        Boolean          @default(false)
  cataract                 Boolean          @default(false)
  goiter                   Boolean          @default(false)
  peptic_ulcer             Boolean          @default(false)
  hypertension             Boolean          @default(false)
  glaucoma                 Boolean          @default(false)
  tuberculosis             Boolean          @default(false)
  haemorrhoids             Boolean          @default(false)
  hepatitis                Boolean          @default(false)
  disease_comments         String?
  created_at               DateTime         @default(now())
  updated_at               DateTime         @updatedAt
  principal_account        PrincipalAccount @relation(fields: [principal_account_id], references: [id])

  @@map("medical_history")
}

model PrincipalRegistration {
  id                   String                  @id @default(cuid())
  first_name           String
  last_name            String
  middle_name          String?
  gender               String
  date_of_birth        DateTime
  phone_number         String
  email                String
  residential_address  String
  profile_picture      String?
  organization_name    String
  organization_code    String?
  organization_id      String?
  organization         Organization?           @relation(fields: [organization_id], references: [id])
  organization_email   String?
  organization_phone   String?
  organization_address String?
  plan_name            String
  plan_type            String?
  plan_id              String?
  plan                 Plan?                   @relation(fields: [plan_id], references: [id])
  primary_hospital     String?
  hospital_address     String?
  remarks              String?
  source               String? // PUBLIC_LINK or MOBILE_APP
  status               String                  @default("PENDING") // PENDING, APPROVED, REJECTED
  submitted_at         DateTime                @default(now())
  reviewed_at          DateTime?
  reviewed_by_id       String?
  reviewed_by          User?                   @relation("ReviewedPrincipalRegistrations", fields: [reviewed_by_id], references: [id])
  approved_at          DateTime?
  approved_by_id       String?
  approved_by          User?                   @relation("ApprovedPrincipalRegistrations", fields: [approved_by_id], references: [id])
  rejected_at          DateTime?
  rejected_by_id       String?
  rejected_by          User?                   @relation("RejectedPrincipalRegistrations", fields: [rejected_by_id], references: [id])
  rejection_reason     String?
  created_at           DateTime                @default(now())
  updated_at           DateTime                @updatedAt
  dependents           DependentRegistration[]

  @@index([email])
  @@index([status])
  @@index([submitted_at])
  @@index([source])
  @@index([organization_id])
  @@index([plan_id])
  @@map("principal_registrations")
}

model DependentRegistration {
  id                        String                @id @default(cuid())
  principal_registration_id String?
  principal_registration    PrincipalRegistration? @relation(fields: [principal_registration_id], references: [id], onDelete: Cascade)
  principal_id              String?
  principal                 PrincipalAccount?      @relation("PrincipalDependentRegistrations", fields: [principal_id], references: [id], onDelete: SetNull)
  first_name                String
  last_name                 String
  middle_name               String?
  date_of_birth             DateTime
  gender                    String?
  relationship              String
  profile_picture           String // MANDATORY
  phone_number              String?
  email                     String?
  residential_address       String?
  status                    String                @default("PENDING") // PENDING, APPROVED, REJECTED
  submitted_at              DateTime              @default(now())
  approved_at               DateTime?
  approved_by_id            String?
  approved_by               User?                 @relation("ApprovedDependentRegistrations", fields: [approved_by_id], references: [id])
  rejected_at               DateTime?
  rejected_by_id            String?
  rejected_by               User?                 @relation("RejectedDependentRegistrations", fields: [rejected_by_id], references: [id])
  rejection_reason          String?
  source                    String?               @default("PUBLIC_LINK") // PUBLIC_LINK or MOBILE_APP
