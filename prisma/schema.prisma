  exchange_rate_date DateTime?
  is_primary         Boolean   @default(false)
  is_secondary       Boolean   @default(false)
  provider_id        String
  tariff_plan_id     String?
  is_draft           Boolean   @default(false)
  status             String    @default("ACTIVE")
  service_type       Int? // 1 = Primary (no approval code), NULL = Secondary (requires approval code)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  provider                  Provider                @relation(fields: [provider_id], references: [id])
  tariff_plan               TariffPlan?             @relation(fields: [tariff_plan_id], references: [id])
  tariff_plan_service_links TariffPlanServiceLink[]

  @@index([category_id])
  @@index([service_id])
  @@index([provider_id])
  @@index([tariff_plan_id])
  @@index([status])
  @@index([is_draft])
  @@index([service_type])
  @@map("tariff_plan_services")
}

model TariffPlanServiceLink {
  id             String   @id @default(cuid())
  tariff_plan_id String
  service_id     String
  created_at     DateTime @default(now())

  tariff_plan TariffPlan        @relation(fields: [tariff_plan_id], references: [id], onDelete: Cascade)
  service     TariffPlanService @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@unique([tariff_plan_id, service_id])
  @@index([tariff_plan_id])
  @@index([service_id])
  @@map("tariff_plan_service_links")
}

model MSA {
  id              String    @id @default(cuid())
  provider_id     String
  tariff_plan_id  String
  document_url    String?
  status          MSAStatus @default(DRAFT)
  generated_at    DateTime?
  generated_by_id String?
  signed_at       DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  provider     Provider   @relation(fields: [provider_id], references: [id])
  tariff_plan  TariffPlan @relation(fields: [tariff_plan_id], references: [id])
  generated_by User?      @relation("GeneratedMSAs", fields: [generated_by_id], references: [id])

  @@index([provider_id])
  @@index([tariff_plan_id])
  @@index([status])
  @@index([generated_at])
  @@map("msas")
}

model PlanBand {
  id          String         @id @default(cuid())
  plan_id     String
  provider_id String
  band_type   String
  status      PlanBandStatus @default(ACTIVE)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  plan        Plan           @relation(fields: [plan_id], references: [id])
  provider    Provider       @relation(fields: [provider_id], references: [id])

  @@index([plan_id])
  @@index([provider_id])
  @@map("plan_bands")
}

// --- Benefit Package Hierarchy ---
// New hierarchical structure for benefit packages: Package -> Category -> Service

model BenefitPackage {
  id             String              @id @default(cuid())
  name           String
  classification BenefitClassification @default(SME)
  description    String?
  price          Decimal?            // Plan price (optional for now)
  is_active      Boolean             @default(true)
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt
  
  categories BenefitCategory[]
  
  @@unique([name, classification])
  @@index([classification])
  @@map("benefit_packages")
}

model BenefitCategory {
  id            String   @id @default(cuid())
  package_id    String
  name          String
  description   String?
  price_limit   Decimal? // Optional category-level amount cap
  display_order Int      @default(0)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  
  package  BenefitPackage   @relation(fields: [package_id], references: [id], onDelete: Cascade)
  services BenefitService[]
  
  @@unique([package_id, name])
  @@index([package_id])
  @@map("benefit_categories")
}

model BenefitService {
  id               String                @id @default(cuid())
  category_id      String
  name             String
  description      String?
  limit_type       BenefitLimitType?    @default(PRICE)  // Optional when NOT_COVERED
  limit_value      Decimal?              // Amount if PRICE, or null if FREQUENCY
  limit_frequency  String?               // e.g., "1 Session/Year" if FREQUENCY
  coverage_status  BenefitCoverageStatus @default(COVERED)
  is_customizable  Boolean               @default(true)
  display_order    Int                   @default(0)
  is_active        Boolean               @default(true)
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt
  
  category BenefitCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  
  @@unique([category_id, name])
  @@index([category_id])
  @@map("benefit_services")
}

enum BenefitClassification {
  SME
  RETAIL
  CORPORATE
}

model PackageLimit {
  id            String           @id @default(cuid())
  plan_id       String?          // Optional - Benefit Packages now works independently from Plans Management
  category      String // Category name (e.g., "Laboratory Services", "Drugs / Pharmaceuticals")
  service_name  String? // Optional specific service name within category
  amount        Decimal // Maximum amount allowed (Limit)
  default_price Decimal? // Default price for the service (if applicable)
  input_type    BenefitInputType @default(NUMBER) // Type of input for customization

  // New Fields for Redesign
  limit_type      BenefitLimitType      @default(PRICE)
  limit_frequency String? // e.g. "1 Session", "Annually"
  coverage_status BenefitCoverageStatus @default(COVERED)

  is_customizable Boolean            @default(true) // Whether this field can be customized
  status          PackageLimitStatus @default(ACTIVE)
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  plan            Plan?              @relation(fields: [plan_id], references: [id])

  // @@unique([plan_id, category]) // Removed unique constraint to allow multiple entries per category (services)
  @@index([plan_id])
  @@index([category])
  @@map("package_limits")
}

enum BenefitInputType {
  NUMBER
  DROPDOWN
  ALPHANUMERIC
}

enum BenefitLimitType {
  PRICE
  FREQUENCY
}

enum BenefitCoverageStatus {
  COVERED
  NOT_COVERED
}

model RiskProfile {
  id              String            @id @default(cuid())
  provider_id     String
  risk_score      Int
  risk_level      RiskLevel
  assessment_date DateTime
  last_reviewed   DateTime
  status          RiskProfileStatus @default(ACTIVE)
  notes           String?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  provider        Provider          @relation("RiskProfiles", fields: [provider_id], references: [id])

  @@index([provider_id])
  @@index([risk_level])
  @@index([status])
  @@map("risk_profiles")
}

model Role {
  id                 String       @id @default(cuid())
  name               String       @unique
  description        String?
  permissions        Json?        @default("[]")
  is_system          Boolean      @default(false)
  is_active          Boolean      @default(true)
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  users              User[]
  permission_records Permission[]

  @@map("roles")
}

model FraudRule {
  id                String            @id @default(cuid())
  name              String
  description       String?
  category          String
  severity          FraudRuleSeverity @default(MEDIUM)
  conditions        String[]
  auto_action       String?
  triggered_count   Int               @default(0)
  is_active         Boolean           @default(true)
  risk_score_weight Int               @default(50)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  created_by_id     String
  created_by        User              @relation("CreatedFraudRules", fields: [created_by_id], references: [id])

  @@map("fraud_rules")
}

model ApprovalCode {
  id                 String                 @id @default(cuid())
  approval_code      String                 @unique
  enrollee_id        String
  enrollee_name      String
  hospital           String
  services           String
  amount             Decimal
  diagnosis          String?
  clinical_encounter String?                // Clinical findings / notes recorded at code generation
  status             ApprovalCodeStatus     @default(PENDING)
  claim_id           String? // Link to claim when created
  generated_by_id    String
  created_at         DateTime               @default(now())
  updated_at         DateTime               @updatedAt
  admission_required Boolean                @default(false)
  is_manual          Boolean                @default(false)
  beneficiary_id     String? // Actual beneficiary ID string (e.g. CJH/001/D01) for display
  provider_id        String? // Optional link to Provider (for manual codes)
  is_deleted         Boolean                @default(false)
  deleted_at         DateTime?
  deleted_by_id      String?
  deletion_reason    String?
  enrollee           PrincipalAccount       @relation(fields: [enrollee_id], references: [id])
  generated_by       User                   @relation("GeneratedApprovalCodes", fields: [generated_by_id], references: [id])
  deleted_by         User?                  @relation("DeletedApprovalCodes", fields: [deleted_by_id], references: [id])
  provider           Provider?              @relation(fields: [provider_id], references: [id])
  claim              Claim?                 @relation(fields: [claim_id], references: [id])
  service_items      ApprovalCodeService[] // Individual service tracking
  timeline           ApprovalCodeTimeline[] // Timeline tracking for audit trail

  @@index([enrollee_id])
  @@index([status])
  @@index([approval_code])
  @@index([claim_id])
  @@map("approval_codes")
}

model ApprovalCodeService {
  id               String       @id @default(cuid())
  approval_code_id String
  service_name     String
  service_amount   Decimal
  added_at         DateTime     @default(now())
  is_initial       Boolean      @default(true) // true for original services, false for later additions
  quantity         Int          @default(1)
  is_ad_hoc        Boolean      @default(false) // true if service was manually added (not from tariff)
  is_added_after_approval Boolean @default(false) // true if service was added after approval code was already approved
  tariff_price     Decimal? // Original tariff price for comparison
  service_id       String? // Optional ID of the original service (ServiceType or TariffPlanService)
  added_by_id      String? // User who added this service (null for initial services)
  
  // Vetting Fields
  vetted_amount    Decimal?
  is_vetted_approved Boolean @default(true)
  rejection_reason String?
  category         String?  // DRG for Drugs, SER for Services, etc.
  is_deleted       Boolean @default(false) // For vetting stage "deletion"

  approval_code    ApprovalCode @relation(fields: [approval_code_id], references: [id], onDelete: Cascade)
  added_by         User?        @relation("AddedApprovalCodeServices", fields: [added_by_id], references: [id])

  @@index([approval_code_id])
  @@index([is_initial])
  @@map("approval_code_services")
}

model ApprovalCodeTimeline {
  id               String   @id @default(cuid())
  approval_code_id String
  stage            String
  timestamp        DateTime @default(now())
  user_id          String?
  provider_id      String?
  delay_minutes    Int?
  created_at       DateTime @default(now())

  approval_code ApprovalCode @relation(fields: [approval_code_id], references: [id], onDelete: Cascade)
  user          User?        @relation("ApprovalCodeTimelineUser", fields: [user_id], references: [id])
  provider      Provider?    @relation("ApprovalCodeTimelineProvider", fields: [provider_id], references: [id])

  @@index([approval_code_id])
  @@index([stage])
  @@index([timestamp])
  @@index([user_id])
  @@index([provider_id])
  @@map("approval_code_timeline")
}

model ProviderRequestItem {
  id                  String  @id @default(cuid())
  provider_request_id String
  service_name        String
  service_amount      Decimal
  quantity            Int     @default(1)

  is_ad_hoc    Boolean  @default(false)
  is_added_after_approval Boolean @default(false) // true if service was added to existing approval code
  tariff_price Decimal?
  category     String?  // Track category at request level too

  created_at DateTime @default(now())

  provider_request ProviderRequest @relation(fields: [provider_request_id], references: [id], onDelete: Cascade)

  @@index([provider_request_id])
  @@map("provider_request_items")
}

model ProcurementInvoice {
  id                     String            @id @default(cuid())
  invoice_number         String            @unique
  service_type           String
  department             String
  amount                 Decimal
  description            String?
  attachment_url         String? // Cloudinary URL of supporting document
  attachment_name        String? // Original filename
  generated_by           String
  status                 ProcurementStatus @default(PENDING)
  rejection_reason       String?
  dept_oversight_comment String?
  dept_oversight_by_id   String?
  dept_oversight_at      DateTime?
  operations_comment     String?
  operations_by_id       String?
  operations_at          DateTime?
  executive_comment      String?
  executive_by_id        String?
  executive_at           DateTime?
  paid_at                DateTime?
  created_by_id          String
  created_at             DateTime          @default(now())
  updated_at             DateTime          @updatedAt
  created_by             User              @relation("CreatedProcurementInvoices", fields: [created_by_id], references: [id])
  dept_oversight_by      User?             @relation("ProcurementDeptOversightBy", fields: [dept_oversight_by_id], references: [id])
  operations_by          User?             @relation("ProcurementOperationsBy", fields: [operations_by_id], references: [id])
  executive_by           User?             @relation("ProcurementExecutiveBy", fields: [executive_by_id], references: [id])

  @@index([invoice_number])
  @@index([status])
  @@index([department])
  @@map("procurement_invoices")
}

model ProviderRequest {
  id               String                @id @default(cuid())
  claim_id         String?
  enrollee_id      String
  provider_id      String
  hospital         String
  services         String // Legacy / Summary
  amount           Decimal
  status           ProviderRequestStatus @default(PENDING)
  rejection_reason String?

  beneficiary_id   String?
  beneficiary_name String?

  // Tariff type field - PRIVATE or NHIA
  tariff_type String? @default("PRIVATE") // 'PRIVATE' or 'NHIA'

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
  admission_required Boolean          @default(false)
  diagnosis          String?
  request_id         String?
  enrollee           PrincipalAccount @relation(fields: [enrollee_id], references: [id])
  provider           Provider         @relation(fields: [provider_id], references: [id])

  request_items ProviderRequestItem[]

  @@index([enrollee_id])
  @@index([provider_id])
  @@index([status])
  @@map("provider_requests")
}

